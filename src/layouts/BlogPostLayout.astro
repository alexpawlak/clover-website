---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AppStoreButtons from '../components/AppStoreButtons.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: 'location-guide' | 'venue-guide';
  heroImage?: string;
}

const { title, description, pubDate, category, heroImage } = Astro.props;

const categoryLabel = category === 'location-guide' ? 'Location Guide' : 'Venue Guide';
const categoryColour = category === 'location-guide'
  ? 'bg-brand-pink/10 text-brand-pink'
  : 'bg-amenity-blue-light/40 text-amenity-blue-dark';

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="py-16">
    <div class="container-custom">
      <div class="max-w-2xl mx-auto">

        <!-- Article header -->
        <div class="mb-10">
          <span class={`inline-block text-xs font-semibold px-3 py-1 rounded-full mb-4 ${categoryColour}`}>
            {categoryLabel}
          </span>
          <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4 leading-tight">
            {title}
          </h1>
          <p class="text-sm text-neutral-500">{formattedDate}</p>
        </div>

        {heroImage && (
          <div class="mb-10 rounded-2xl overflow-hidden">
            <img
              src={heroImage}
              alt={title}
              class="w-full h-64 md:h-80 object-cover"
            />
          </div>
        )}

        <!-- Article body -->
        <article class="prose prose-neutral max-w-none
          prose-headings:font-bold prose-headings:text-neutral-900
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
          prose-p:text-neutral-700 prose-p:leading-relaxed
          prose-a:text-brand-pink prose-a:no-underline hover:prose-a:underline
          prose-strong:text-neutral-900">
          <slot />
        </article>

        <!-- CTA -->
        <div class="mt-16 bg-brand-pink rounded-2xl p-8 text-white text-center">
          <h2 class="text-xl font-bold mb-2">Find changing facilities near you</h2>
          <p class="text-sm opacity-90 mb-6">
            Clover shows baby changing tables, nursing rooms, and family facilities on a map, wherever you are in the UK.
          </p>
          <AppStoreButtons />
        </div>

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
