---
export const prerender = false;

import StudioLayout from '../../layouts/StudioLayout.astro';
import { requireAuth } from '../../lib/auth';
import { supabaseAdmin } from '../../lib/supabase-admin';
import { STUDIO_NAME } from '../../lib/studio-meta';

const { redirect } = await requireAuth(Astro.cookies);
if (redirect) return Astro.redirect(redirect);

const { data: places } = await supabaseAdmin
  .from('places')
  .select('id, name, city')
  .order('name');

const allPlacesData = (places ?? []).map(pl => ({
  id: pl.id,
  name: pl.name,
  city: pl.city ?? null,
  label: pl.name + (pl.city ? ` \u2014 ${pl.city}` : ''),
}));
---

<StudioLayout title={`Photos — ${STUDIO_NAME}`} active="photos" widthMode="wide">
  <div class="photo-manager">
    <div class="photo-toolbar">
      <div class="photo-search-picker">
        <input type="text" id="photo-place-search" class="photo-search-input" placeholder="Search by place name..." autocomplete="off" aria-label="Search POI photos" />
        <ul class="photo-search-dropdown" id="photo-place-dropdown" role="listbox"></ul>
      </div>
      <div class="photo-size-selector" id="photo-size-selector" role="group" aria-label="Photo size">
        <button type="button" class="photo-size-option" data-size="compact" aria-label="Small photos">S</button>
        <button type="button" class="photo-size-option" data-size="comfortable" aria-label="Medium photos">M</button>
        <button type="button" class="photo-size-option" data-size="large" aria-label="Large photos">L</button>
      </div>
    </div>

    <div class="photo-summary">
      <div class="photo-summary-title" id="photo-summary-title">Loading latest uploaded photos...</div>
      <div class="photo-summary-meta" id="photo-summary-meta"></div>
    </div>

    <div class="photo-gallery" id="photo-gallery" aria-live="polite"></div>
    <div class="photo-empty" id="photo-empty" hidden></div>
  </div>

  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script is:inline define:vars={{ allPlacesData }}>
    window.__allPlaces = allPlacesData;
  </script>

  <script>
    type PlaceOption = {
      id: string;
      name: string;
      city: string | null;
      label: string;
      source: 'supabase';
    };
    type PlacePhoto = {
      id: string;
      place_id: string;
      url: string;
      created_at: string;
      display_order?: number | null;
      session_id?: string | null;
      user_id?: string | null;
      place_name?: string | null;
      place_city?: string | null;
    };

    const supabasePlaces: PlaceOption[] = ((window as any).__allPlaces ?? []).map((p: { id: string; name: string; city: string | null; label: string }) => ({
      ...p,
      source: 'supabase' as const,
    }));

    const photoPlaceSearch = document.getElementById('photo-place-search') as HTMLInputElement;
    const photoPlaceDropdown = document.getElementById('photo-place-dropdown') as HTMLUListElement;
    const photoGallery = document.getElementById('photo-gallery') as HTMLDivElement;
    const photoEmpty = document.getElementById('photo-empty') as HTMLDivElement;
    const photoSummaryTitle = document.getElementById('photo-summary-title') as HTMLDivElement;
    const photoSummaryMeta = document.getElementById('photo-summary-meta') as HTMLDivElement;
    const photoSizeSelector = document.getElementById('photo-size-selector') as HTMLDivElement;

    type DropPosition = 'before' | 'after';
    type PhotoSize = 'compact' | 'comfortable' | 'large';
    const trashIcon = `
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M9 3.75A2.25 2.25 0 0 0 6.75 6H4.5a.75.75 0 0 0 0 1.5h.81l.72 10.18A2.25 2.25 0 0 0 8.27 19.8h7.46a2.25 2.25 0 0 0 2.24-2.12l.72-10.18h.81a.75.75 0 0 0 0-1.5h-2.25A2.25 2.25 0 0 0 15 3.75H9Zm0 1.5h6A.75.75 0 0 1 15.75 6h-7.5A.75.75 0 0 1 9 5.25Zm-.22 4.5a.75.75 0 0 1 .75.7l.25 5.5a.75.75 0 1 1-1.5.06l-.25-5.5a.75.75 0 0 1 .7-.76h.05Zm6.44 0a.75.75 0 0 1 .7.76l-.25 5.5a.75.75 0 1 1-1.5-.06l.25-5.5a.75.75 0 0 1 .75-.7h.05ZM12 9.75a.75.75 0 0 1 .75.75V16a.75.75 0 0 1-1.5 0v-5.5a.75.75 0 0 1 .75-.75Z"/>
      </svg>
    `;

    let photoFeedMode: 'latest' | 'place' = 'latest';
    let selectedPhotoPlace: PlaceOption | null = null;
    let currentPhotos: PlacePhoto[] = [];
    let lastCommittedPlacePhotos: PlacePhoto[] = [];
    const pendingPhotoDelete = new Set<string>();
    let draggedPhotoId: string | null = null;
    let dragPreviewTargetId: string | null = null;
    let dragPreviewPosition: DropPosition | null = null;
    let isSavingPhotoOrder = false;
    let photoSize: PhotoSize = 'comfortable';

    function showToast(msg: string) {
      const el = document.getElementById('toast')!;
      el.textContent = msg;
      el.classList.add('show');
      setTimeout(() => el.classList.remove('show'), 3000);
    }

    function formatPhotoDate(iso: string) {
      return new Date(iso).toLocaleString('en-GB', {
        day: 'numeric',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit',
      });
    }

    function getPhotoTitle(photo: PlacePhoto) {
      if (photoFeedMode === 'latest') {
        return photo.place_name ?? photo.place_id;
      }

      return `Position ${(photo.display_order ?? currentPhotos.indexOf(photo)) + 1}`;
    }

    function readStoredPhotoSize(): PhotoSize {
      try {
        const raw = window.localStorage.getItem('partner-portal-photo-size');
        if (raw === 'compact' || raw === 'comfortable' || raw === 'large') return raw;
      } catch {
        return 'comfortable';
      }
      return 'comfortable';
    }

    function applyPhotoSize() {
      photoGallery.classList.remove('photo-gallery-size-compact', 'photo-gallery-size-comfortable', 'photo-gallery-size-large');
      photoGallery.classList.add(`photo-gallery-size-${photoSize}`);

      photoSizeSelector.querySelectorAll<HTMLButtonElement>('.photo-size-option').forEach(button => {
        const isActive = button.dataset.size === photoSize;
        button.classList.toggle('active', isActive);
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });
    }

    function setPhotoSize(nextSize: PhotoSize) {
      if (photoSize === nextSize) return;
      photoSize = nextSize;
      try {
        window.localStorage.setItem('partner-portal-photo-size', nextSize);
      } catch {
        // Ignore storage failures and keep the in-memory choice.
      }
      applyPhotoSize();
      renderPhotoState();
    }

    function renderPhotoState() {
      photoGallery.innerHTML = '';
      photoGallery.classList.toggle('photo-gallery-ordered', photoFeedMode === 'place');
      photoGallery.classList.toggle('photo-gallery-latest', photoFeedMode === 'latest');
      applyPhotoSize();

      if (photoFeedMode === 'latest') {
        photoSummaryTitle.textContent = 'Latest uploaded photos';
      } else if (selectedPhotoPlace) {
        photoSummaryTitle.textContent = `Photos for ${selectedPhotoPlace.name}${selectedPhotoPlace.city ? `, ${selectedPhotoPlace.city}` : ''}`;
      } else {
        photoSummaryTitle.textContent = 'Latest uploaded photos';
      }
      const summaryParts = [`${currentPhotos.length} photo${currentPhotos.length === 1 ? '' : 's'}`];
      if (photoFeedMode === 'place') summaryParts.push('First photo appears first in the app');
      if (draggedPhotoId && dragPreviewTargetId && dragPreviewPosition) {
        summaryParts.push(`Preview: insert ${dragPreviewPosition}`);
      }
      if (isSavingPhotoOrder) summaryParts.push('Saving order...');
      photoSummaryMeta.textContent = summaryParts.join(' • ');

      if (currentPhotos.length === 0) {
        photoEmpty.hidden = false;
        photoEmpty.innerHTML = photoFeedMode === 'latest'
          ? '<strong>No photos uploaded yet</strong>Recent uploads will appear here automatically.'
          : '<strong>No photos yet</strong>This place does not have any uploaded photos.';
        return;
      }

      photoEmpty.hidden = true;

      currentPhotos.forEach(photo => {
        const card = document.createElement('article');
        card.className = 'photo-card';
        card.id = `photo-${photo.id}`;
        card.dataset.photoId = photo.id;
        if (photoFeedMode === 'place' && photo.id === dragPreviewTargetId && dragPreviewPosition) {
          card.classList.add('photo-card-drop-target', `photo-card-drop-target-${dragPreviewPosition}`);
        }

        const thumbWrap = document.createElement('div');
        thumbWrap.className = 'photo-thumb-wrap';

        const img = document.createElement('img');
        img.className = 'photo-thumb';
        img.src = photo.url;
        const placeName = photoFeedMode === 'latest'
          ? (photo.place_name ?? photo.place_id)
          : (selectedPhotoPlace?.name ?? photo.place_name ?? photo.place_id);
        const placeCity = photoFeedMode === 'latest'
          ? (photo.place_city ?? null)
          : (selectedPhotoPlace?.city ?? photo.place_city ?? null);
        const placeLabel = `${placeName}${placeCity ? `, ${placeCity}` : ''}`;
        img.alt = `Photo uploaded for ${placeLabel}`;
        img.loading = 'lazy';

        const deleteBtn = document.createElement('button');
        deleteBtn.type = 'button';
        deleteBtn.className = 'photo-delete-btn';
        deleteBtn.innerHTML = trashIcon;
        deleteBtn.setAttribute('aria-label', pendingPhotoDelete.has(photo.id) ? 'Confirm remove photo' : 'Remove photo');
        deleteBtn.title = pendingPhotoDelete.has(photo.id) ? 'Confirm remove photo' : 'Remove photo';
        if (pendingPhotoDelete.has(photo.id)) deleteBtn.classList.add('confirm');
        deleteBtn.addEventListener('click', () => void handlePhotoDelete(photo.id));

        if (photoFeedMode === 'place') {
          card.draggable = !isSavingPhotoOrder;
          card.classList.add('photo-card-draggable');
          card.addEventListener('dragstart', (event) => handlePhotoDragStart(event, photo.id));
          card.addEventListener('dragover', (event) => handlePhotoDragOver(event, photo.id));
          card.addEventListener('drop', (event) => void handlePhotoDrop(event, photo.id));
          card.addEventListener('dragend', handlePhotoDragEnd);
        }

        const overlay = document.createElement('div');
        overlay.className = 'photo-card-overlay';

        const title = document.createElement('div');
        title.className = 'photo-card-title';
        title.textContent = getPhotoTitle(photo);

        const hoverMeta = document.createElement('div');
        hoverMeta.className = 'photo-card-hover-meta';
        hoverMeta.textContent = formatPhotoDate(photo.created_at);

        if (photoFeedMode === 'place') {
          const dragHint = document.createElement('div');
          dragHint.className = 'photo-order-hint';
          if (isSavingPhotoOrder) {
            dragHint.textContent = 'Saving new order...';
          } else if (photo.id === dragPreviewTargetId && dragPreviewPosition) {
            dragHint.textContent = dragPreviewPosition === 'before' ? 'Drop before this photo' : 'Drop after this photo';
          } else {
            dragHint.textContent = 'Drag to reorder';
          }
          hoverMeta.appendChild(dragHint);
        }

        overlay.appendChild(title);
        overlay.appendChild(hoverMeta);
        thumbWrap.appendChild(img);
        thumbWrap.appendChild(overlay);
        thumbWrap.appendChild(deleteBtn);
        card.appendChild(thumbWrap);
        photoGallery.appendChild(card);
      });
    }

    async function loadLatestPhotos() {
      photoFeedMode = 'latest';
      selectedPhotoPlace = null;
      lastCommittedPlacePhotos = [];
      draggedPhotoId = null;
      dragPreviewTargetId = null;
      dragPreviewPosition = null;
      isSavingPhotoOrder = false;
      photoSummaryTitle.textContent = 'Loading latest uploaded photos...';
      photoSummaryMeta.textContent = '';
      photoEmpty.hidden = true;
      photoGallery.innerHTML = '';

      try {
        const res = await fetch('/api/partner-portal/photos');
        const body = await res.json().catch(() => null);

        if (!res.ok) {
          showToast(body?.error ?? 'Could not load recent photos. Please try again.');
          currentPhotos = [];
        } else {
          currentPhotos = Array.isArray(body) ? body : [];
        }
      } catch {
        currentPhotos = [];
        showToast('Network error loading recent photos. Please try again.');
      }

      renderPhotoState();
    }

    async function loadPhotoGallery(place: PlaceOption) {
      photoFeedMode = 'place';
      selectedPhotoPlace = place;
      draggedPhotoId = null;
      dragPreviewTargetId = null;
      dragPreviewPosition = null;
      isSavingPhotoOrder = false;
      photoSummaryTitle.textContent = `Loading photos for ${place.name}${place.city ? `, ${place.city}` : ''}...`;
      photoSummaryMeta.textContent = '';
      photoEmpty.hidden = true;
      photoGallery.innerHTML = '';

      try {
        const res = await fetch(`/api/partner-portal/photos?place_id=${encodeURIComponent(place.id)}`);
        const body = await res.json().catch(() => null);

        if (!res.ok) {
          showToast(body?.error ?? 'Could not load photos. Please try again.');
          currentPhotos = [];
        } else {
          currentPhotos = Array.isArray(body) ? body : [];
          lastCommittedPlacePhotos = currentPhotos.map(photo => ({ ...photo }));
        }
      } catch {
        currentPhotos = [];
        showToast('Network error loading photos. Please try again.');
      }

      renderPhotoState();
    }

    async function handlePhotoDelete(photoId: string) {
      if (!currentPhotos.find(item => item.id === photoId)) return;

      const btn = document.querySelector(`#photo-${photoId} .photo-delete-btn`) as HTMLButtonElement | null;
      if (!pendingPhotoDelete.has(photoId)) {
        pendingPhotoDelete.add(photoId);
        if (btn) {
          btn.classList.add('confirm');
          btn.setAttribute('aria-label', 'Confirm remove photo');
          btn.title = 'Confirm remove photo';
        }
        setTimeout(() => {
          if (pendingPhotoDelete.has(photoId)) {
            pendingPhotoDelete.delete(photoId);
            renderPhotoState();
          }
        }, 3000);
        return;
      }

      pendingPhotoDelete.delete(photoId);
      if (btn) {
        btn.disabled = true;
        btn.setAttribute('aria-label', 'Removing photo');
        btn.title = 'Removing photo';
      }

      try {
        const res = await fetch(`/api/partner-portal/photos/${photoId}`, { method: 'DELETE' });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          showToast(body.error ?? 'Could not remove photo. Please try again.');
          renderPhotoState();
          return;
        }

        currentPhotos = currentPhotos.filter(item => item.id !== photoId);
        if (photoFeedMode === 'place') {
          dragPreviewTargetId = null;
          dragPreviewPosition = null;
          draggedPhotoId = null;
          currentPhotos = currentPhotos.map((item, index) => ({ ...item, display_order: index }));
          lastCommittedPlacePhotos = currentPhotos.map(photo => ({ ...photo }));
        }
        showToast('Photo removed');
        renderPhotoState();
      } catch {
        showToast('Network error removing photo. Please try again.');
        renderPhotoState();
      }
    }

    function handlePhotoDragStart(event: DragEvent, photoId: string) {
      if (photoFeedMode !== 'place' || isSavingPhotoOrder) return;
      draggedPhotoId = photoId;
      dragPreviewTargetId = null;
      dragPreviewPosition = null;
      event.dataTransfer?.setData('text/plain', photoId);
      event.dataTransfer!.effectAllowed = 'move';
      const card = document.getElementById(`photo-${photoId}`);
      card?.classList.add('dragging');
    }

    function getDragPreviewPosition(event: DragEvent, photoId: string): DropPosition | null {
      const card = document.getElementById(`photo-${photoId}`);
      if (!card) return null;
      const bounds = card.getBoundingClientRect();
      return event.clientY < bounds.top + (bounds.height / 2) ? 'before' : 'after';
    }

    function clearPhotoDragPreview(resetToCommitted = true) {
      dragPreviewTargetId = null;
      dragPreviewPosition = null;
      if (resetToCommitted) {
        currentPhotos = lastCommittedPlacePhotos.map(photo => ({ ...photo }));
      }
    }

    function handlePhotoDragOver(event: DragEvent, targetPhotoId: string) {
      if (photoFeedMode !== 'place' || isSavingPhotoOrder || !draggedPhotoId) return;
      event.preventDefault();
      event.dataTransfer!.dropEffect = 'move';

      const dropPosition = getDragPreviewPosition(event, targetPhotoId);
      if (!dropPosition) return;

      const previewSource = lastCommittedPlacePhotos.length > 0
        ? lastCommittedPlacePhotos
        : currentPhotos;
      const nextPhotos = reorderPhotos(previewSource, draggedPhotoId, targetPhotoId, dropPosition);

      dragPreviewTargetId = targetPhotoId;
      dragPreviewPosition = dropPosition;
      currentPhotos = nextPhotos ?? previewSource.map(photo => ({ ...photo }));
      renderPhotoState();
    }

    function handlePhotoDragEnd() {
      document.querySelectorAll('.photo-card.dragging').forEach(card => card.classList.remove('dragging'));
      if (!isSavingPhotoOrder) {
        clearPhotoDragPreview();
        renderPhotoState();
      }
      draggedPhotoId = null;
    }

    function reorderPhotos(photos: PlacePhoto[], draggedId: string, targetId: string, position: DropPosition) {
      const next = [...photos];
      const fromIndex = next.findIndex(photo => photo.id === draggedId);
      const toIndex = next.findIndex(photo => photo.id === targetId);
      if (fromIndex === -1 || toIndex === -1 || fromIndex === toIndex) return null;

      const [moved] = next.splice(fromIndex, 1);
      let insertIndex = toIndex;
      if (fromIndex < toIndex) insertIndex -= 1;
      if (position === 'after') insertIndex += 1;
      next.splice(insertIndex, 0, moved);

      if (next.every((photo, index) => photo.id === photos[index]?.id)) {
        return null;
      }

      return next.map((photo, index) => ({ ...photo, display_order: index }));
    }

    async function persistPhotoOrder(nextPhotos: PlacePhoto[]) {
      if (!selectedPhotoPlace) return;

      isSavingPhotoOrder = true;
      currentPhotos = nextPhotos;
      renderPhotoState();

      try {
        const res = await fetch('/api/partner-portal/photos/order', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            place_id: selectedPhotoPlace.id,
            photo_ids: nextPhotos.map(photo => photo.id),
          }),
        });
        const body = await res.json().catch(() => null);

        if (!res.ok) {
          currentPhotos = lastCommittedPlacePhotos.map(photo => ({ ...photo }));
          dragPreviewTargetId = null;
          dragPreviewPosition = null;
          showToast(body?.error ?? 'Could not save photo order. Please try again.');
          return;
        }

        lastCommittedPlacePhotos = nextPhotos.map(photo => ({ ...photo }));
        dragPreviewTargetId = null;
        dragPreviewPosition = null;
        showToast('Photo order updated');
      } catch {
        currentPhotos = lastCommittedPlacePhotos.map(photo => ({ ...photo }));
        dragPreviewTargetId = null;
        dragPreviewPosition = null;
        showToast('Network error saving photo order. Please try again.');
      } finally {
        isSavingPhotoOrder = false;
        renderPhotoState();
      }
    }

    async function handlePhotoDrop(event: DragEvent, targetPhotoId: string) {
      if (photoFeedMode !== 'place' || isSavingPhotoOrder) return;
      event.preventDefault();

      const sourcePhotoId = draggedPhotoId ?? event.dataTransfer?.getData('text/plain') ?? null;
      const dropPosition = getDragPreviewPosition(event, targetPhotoId);
      if (!sourcePhotoId || sourcePhotoId === targetPhotoId || !dropPosition) return;

      const previewSource = lastCommittedPlacePhotos.length > 0
        ? lastCommittedPlacePhotos
        : currentPhotos;
      const nextPhotos = reorderPhotos(previewSource, sourcePhotoId, targetPhotoId, dropPosition);
      if (!nextPhotos) {
        clearPhotoDragPreview();
        renderPhotoState();
        return;
      }

      dragPreviewTargetId = null;
      dragPreviewPosition = null;
      await persistPhotoOrder(nextPhotos);
    }

    function renderPhotoSearchDropdown(query: string) {
      const q = query.toLowerCase().trim();
      const matches = q.length === 0
        ? []
        : supabasePlaces.filter(place => place.label.toLowerCase().includes(q)).slice(0, 12);

      photoPlaceDropdown.innerHTML = '';
      if (matches.length === 0) {
        photoPlaceDropdown.classList.remove('open');
        return;
      }

      matches.forEach(place => {
        const li = document.createElement('li');
        li.setAttribute('role', 'option');

        const name = document.createElement('span');
        name.className = 'photo-search-name';
        name.textContent = place.name;

        const city = document.createElement('span');
        city.className = 'photo-search-city';
        city.textContent = place.city ?? 'No city';

        li.appendChild(name);
        li.appendChild(city);
        li.addEventListener('mousedown', (e) => {
          e.preventDefault();
          photoPlaceSearch.value = place.label;
          photoPlaceDropdown.classList.remove('open');
          void loadPhotoGallery(place);
        });
        photoPlaceDropdown.appendChild(li);
      });

      photoPlaceDropdown.classList.add('open');
    }

    photoPlaceSearch.addEventListener('input', () => {
      if (photoPlaceSearch.value.trim() === '') {
        photoPlaceDropdown.classList.remove('open');
        void loadLatestPhotos();
        return;
      }
      renderPhotoSearchDropdown(photoPlaceSearch.value);
    });
    photoPlaceSearch.addEventListener('focus', () => renderPhotoSearchDropdown(photoPlaceSearch.value));
    photoPlaceSearch.addEventListener('blur', () => {
      setTimeout(() => photoPlaceDropdown.classList.remove('open'), 150);
    });

    photoSizeSelector.querySelectorAll<HTMLButtonElement>('.photo-size-option').forEach(button => {
      button.addEventListener('click', () => {
        const nextSize = button.dataset.size;
        if (nextSize === 'compact' || nextSize === 'comfortable' || nextSize === 'large') {
          setPhotoSize(nextSize);
        }
      });
    });

    photoSize = readStoredPhotoSize();
    applyPhotoSize();
    void loadLatestPhotos();
  </script>
</StudioLayout>
