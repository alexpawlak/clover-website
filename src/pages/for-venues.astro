---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="For Venues — Clover"
  description="Make your venue visible to parents searching for baby-friendly facilities. List your changing tables, nursing rooms, and family amenities on Clover."
>
  <Header />

  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-br from-amenity-blue-light/20 to-white py-20">
      <div class="container-custom text-center max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 bg-amenity-blue-light/40 text-amenity-blue-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-6">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          For venue owners
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-6">
          Be the venue<br /><span class="text-amenity-blue-dark">parents find first</span>
        </h1>
        <p class="text-lg text-neutral-600 mb-10 leading-relaxed">
          Thousands of parents use Clover to find baby-friendly facilities before they visit. If you have a changing table, nursing room, or family restroom — make sure they can find you.
        </p>
        <a href="mailto:alexpawlak+babymap@gmail.com?subject=List%20my%20venue" class="btn-primary text-lg px-8 py-4">
          Get listed free
        </a>
        <p class="mt-4 text-sm text-neutral-500">No account needed. We'll get you listed within 48 hours.</p>
      </div>
    </section>

    <!-- Why list section -->
    <section class="py-20 bg-white">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">Why list your venue?</h2>
          <p class="text-lg text-neutral-600">Parents plan ahead. They search for facilities before they leave the house.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
          <div class="card p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-brand-pink/10 flex items-center justify-center mx-auto mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#E91E63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-2">Get discovered</h3>
            <p class="text-sm text-neutral-600">Parents search by location and filter by facility type. Show up when it matters.</p>
          </div>

          <div class="card p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-amenity-blue-light/40 flex items-center justify-center mx-auto mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0875A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-2">Build trust</h3>
            <p class="text-sm text-neutral-600">Parents leave reviews and photos. A well-reviewed venue attracts more families.</p>
          </div>

          <div class="card p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-amenity-green-light/40 flex items-center justify-center mx-auto mb-4">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#55711E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-2">It's free</h3>
            <p class="text-sm text-neutral-600">Basic listings are completely free. No subscription, no credit card.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What you can list -->
    <section class="py-20 bg-neutral-100">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">What facilities can you list?</h2>
          <p class="text-lg text-neutral-600">If you have any of these, parents are searching for you.</p>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto">
          <div class="bg-white rounded-2xl p-5 text-center border border-brand-pink-light">
            <div class="w-10 h-10 rounded-xl bg-brand-pink/10 flex items-center justify-center mx-auto mb-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E91E63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-neutral-900">Changing table</p>
          </div>

          <div class="bg-white rounded-2xl p-5 text-center border border-amenity-blue-light">
            <div class="w-10 h-10 rounded-xl bg-amenity-blue-light/40 flex items-center justify-center mx-auto mb-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0875A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-neutral-900">Family restroom</p>
          </div>

          <div class="bg-white rounded-2xl p-5 text-center border border-amenity-green-light">
            <div class="w-10 h-10 rounded-xl bg-amenity-green-light/40 flex items-center justify-center mx-auto mb-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#55711E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-neutral-900">Nursing room</p>
          </div>

          <div class="bg-white rounded-2xl p-5 text-center border border-amenity-orange-light">
            <div class="w-10 h-10 rounded-xl bg-amenity-orange-light/40 flex items-center justify-center mx-auto mb-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A25D0C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 11l19-9-9 19-2-8-8-2z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-neutral-900">Highchair</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-brand-pink text-white">
      <div class="container-custom text-center max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to get listed?</h2>
        <p class="text-lg mb-8 opacity-90">
          Send us your venue details and we'll have you on the map within 48 hours.
        </p>
        <a href="mailto:alexpawlak+babymap@gmail.com?subject=List%20my%20venue" class="inline-block bg-white text-brand-pink font-bold px-8 py-4 rounded-xl hover:bg-neutral-100 transition-colors text-lg">
          Email us to get listed
        </a>
        <p class="mt-6 text-sm opacity-75">Or find us at alexpawlak+babymap@gmail.com</p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
