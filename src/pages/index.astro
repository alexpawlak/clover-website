---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import AppStoreButtons from '../components/AppStoreButtons.astro';
---

<BaseLayout title="Clover - Find Baby Changing Places Near You">
  <Header />
  
  <main>
    <Hero />
    <Features />
    
    <!-- How It Works Section -->
    <section class="py-20 bg-neutral-100">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
            How It Works
          </h2>
          <p class="text-lg text-neutral-600">
            Finding baby-friendly facilities has never been easier
          </p>
        </div>

        <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-start gap-0">

          <div class="text-center flex-1 px-4">
            <div class="w-16 h-16 border-2 border-brand-pink text-brand-pink rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              1
            </div>
            <h3 class="text-xl font-semibold text-neutral-900 mb-2">Open the App</h3>
            <p class="text-neutral-600">Launch Clover and see nearby baby-friendly places on an interactive map</p>
          </div>

          <div class="hidden md:block h-px w-12 bg-neutral-300 flex-shrink-0 mt-8"></div>

          <div class="text-center flex-1 px-4">
            <div class="w-16 h-16 border-2 border-amenity-blue-dark text-amenity-blue-dark rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              2
            </div>
            <h3 class="text-xl font-semibold text-neutral-900 mb-2">Find & Filter</h3>
            <p class="text-neutral-600">Search or filter by amenity type to find exactly what you need</p>
          </div>

          <div class="hidden md:block h-px w-12 bg-neutral-300 flex-shrink-0 mt-8"></div>

          <div class="text-center flex-1 px-4">
            <div class="w-16 h-16 border-2 border-amenity-green-dark text-amenity-green-dark rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              3
            </div>
            <h3 class="text-xl font-semibold text-neutral-900 mb-2">Navigate & Go</h3>
            <p class="text-neutral-600">Get directions and visit with confidence knowing what to expect</p>
          </div>

        </div>
      </div>
    </section>

    <!-- Community Section -->
    <section class="py-20 bg-white">
      <div class="container-custom">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-6">
            Built by Parents, for Parents
          </h2>
          <p class="text-lg text-neutral-600 mb-8">
            Clover is powered by a community of parents helping each other. Add new places, upload photos, and share your experiences to help fellow parents navigate the world with their little ones.
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
            <div class="card p-6 text-center">
              <div class="w-10 h-10 rounded-xl bg-brand-pink/10 flex items-center justify-center mx-auto mb-4">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E91E63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/>
                  <circle cx="12" cy="9" r="2.5"/>
                </svg>
              </div>
              <h3 class="font-semibold text-neutral-900 mb-1">Add Places</h3>
              <p class="text-sm text-neutral-600">Found a great spot? Share it with the community</p>
            </div>
            <div class="card p-6 text-center">
              <div class="w-10 h-10 rounded-xl bg-amenity-blue-light/40 flex items-center justify-center mx-auto mb-4">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0875A0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/>
                  <circle cx="12" cy="13" r="4"/>
                </svg>
              </div>
              <h3 class="font-semibold text-neutral-900 mb-1">Upload Photos</h3>
              <p class="text-sm text-neutral-600">Help others see what to expect before they visit</p>
            </div>
            <div class="card p-6 text-center">
              <div class="w-10 h-10 rounded-xl bg-amenity-orange-light/40 flex items-center justify-center mx-auto mb-4">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A25D0C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              </div>
              <h3 class="font-semibold text-neutral-900 mb-1">Share Feedback</h3>
              <p class="text-sm text-neutral-600">Report issues to keep information accurate</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Download CTA Section -->
    <section id="download" class="py-20 bg-brand-pink text-white">
      <div class="container-custom text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Ready to Get Started?
        </h2>
        <p class="text-lg mb-8 opacity-90 max-w-2xl mx-auto">
          Download Clover today and join thousands of parents who never worry about finding baby-changing facilities again.
        </p>
        <AppStoreButtons />
        <p class="mt-6 text-sm opacity-75">
          Free to download on iOS • Android version not released yet, coming in a few days
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
