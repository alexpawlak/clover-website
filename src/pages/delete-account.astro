---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Delete App Account - Clover"
  description="Request deletion of your Clover app account and associated data for Android and iOS."
>
  <Header />

  <main>
    <section class="py-20 bg-gradient-to-br from-red-50 via-white to-brand-pink-light/20">
      <div class="container-custom">
        <div class="max-w-2xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-4">Delete Your App Account</h1>
          <p class="text-neutral-700 mb-3">
            This page is for Clover mobile app users on Android and iOS.
          </p>
          <p class="text-neutral-600 text-base md:text-lg">
            Request deletion of your app account and associated data under GDPR rights.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="container-custom max-w-2xl">
        <div class="card p-8 border border-red-100">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">How to request deletion</h2>
          <ol class="list-decimal list-inside text-neutral-700 space-y-3 mb-8">
            <li>Send an email with subject <strong>Data Deletion Request</strong>.</li>
            <li>Include your Clover app account email (or Apple private relay email, if used).</li>
            <li>Include your platform: Android or iOS.</li>
            <li>Optionally include details about photos you uploaded (city/place/date) to speed up processing.</li>
          </ol>

          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="mailto:alexpawlak+babymap@gmail.com?subject=Data%20Deletion%20Request&body=Platform%3A%20Android%20or%20iOS%0AAccount%20email%3A%20%0ADetails%20(optional)%3A%20"
              class="btn-primary bg-red-600 hover:bg-red-700"
            >
              Request deletion by email
            </a>
            <a href="/privacy" class="btn-outline border-neutral-300 text-neutral-700 hover:border-brand-pink hover:text-white">
              Review privacy policy
            </a>
          </div>

          <p class="mt-5 text-sm text-neutral-600">
            We process deletion requests within 30 days.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>