---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getUser } from '../lib/auth';

const user = await getUser(Astro.cookies);
if (!user) {
  return Astro.redirect('/partner-portal/login?next=/delete-account');
}
---

<BaseLayout
  title="Delete Account - Clover"
  description="Delete your Clover account and remove uploaded photos linked to your account."
>
  <Header />

  <main>
    <section class="py-20 bg-gradient-to-br from-red-50 via-white to-brand-pink-light/20">
      <div class="container-custom">
        <div class="max-w-2xl mx-auto">
          <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-4">Delete Your Account</h1>
          <p class="text-neutral-700 mb-3">
            This action is permanent and cannot be undone.
          </p>
          <p class="text-neutral-600 text-base md:text-lg">
            Signed in as <strong>{user.email ?? user.id}</strong>
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="container-custom max-w-2xl">
        <div class="card p-8 border border-red-100">
          <h2 class="text-2xl font-bold text-neutral-900 mb-4">What will be deleted</h2>
          <ul class="list-disc list-inside text-neutral-700 space-y-2 mb-8">
            <li>Your Clover account identity (email, Apple, or Google linked login)</li>
            <li>Photos uploaded from your account</li>
            <li>Your active web session</li>
          </ul>

          <label for="confirm-delete" class="flex items-start gap-3 mb-6 cursor-pointer">
            <input id="confirm-delete" type="checkbox" class="mt-1 h-4 w-4" />
            <span class="text-neutral-700 text-sm md:text-base">
              I understand this permanently deletes my account and uploaded photos.
            </span>
          </label>

          <div class="flex flex-col sm:flex-row gap-3">
            <button id="delete-account-button" class="btn-primary bg-red-600 hover:bg-red-700" disabled>
              Delete my account
            </button>
            <a href="/privacy" class="btn-outline border-neutral-300 text-neutral-700 hover:border-brand-pink hover:text-white">
              Review privacy policy
            </a>
          </div>

          <p id="delete-account-status" class="mt-4 text-sm text-neutral-600" aria-live="polite"></p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const checkbox = document.getElementById('confirm-delete');
  const deleteButton = document.getElementById('delete-account-button');
  const statusEl = document.getElementById('delete-account-status');

  if (checkbox instanceof HTMLInputElement && deleteButton instanceof HTMLButtonElement && statusEl) {
    checkbox.addEventListener('change', () => {
      deleteButton.disabled = !checkbox.checked;
    });

    deleteButton.addEventListener('click', async () => {
      const confirmed = window.confirm(
        'Delete your Clover account and uploaded photos permanently? This cannot be undone.'
      );
      if (!confirmed) return;

      deleteButton.disabled = true;
      deleteButton.textContent = 'Deleting account...';
      statusEl.textContent = 'Processing deletion request...';

      try {
        const response = await fetch('/api/auth/delete-account', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({}),
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok) {
          statusEl.textContent = payload?.error ?? 'Could not delete your account. Please try again.';
          deleteButton.disabled = !checkbox.checked;
          deleteButton.textContent = 'Delete my account';
          return;
        }

        statusEl.textContent = 'Your account and linked photos have been deleted. Redirecting...';
        window.setTimeout(() => {
          window.location.href = '/';
        }, 1200);
      } catch {
        statusEl.textContent = 'Network error while deleting your account. Please retry.';
        deleteButton.disabled = !checkbox.checked;
        deleteButton.textContent = 'Delete my account';
      }
    });
  }
</script>