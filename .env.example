# Supabase project URL — found in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key — used for auth sign-in
SUPABASE_ANON_KEY=eyJ...

# Supabase service role key — server-only, bypasses RLS for admin DB access
# Found in Supabase dashboard → Project Settings → API → service_role key
# NEVER expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJ...
